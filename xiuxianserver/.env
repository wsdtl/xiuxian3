# 项目配置入口。
# 只放经常变化的配置和自定义配置。
# 日志等系统默认配置已经写在 launch/config.py 中，非必要不用放这里。


# 项目基础配置
PROJECT_NAME=xiuxian
PROJECT_DEBUG=false
PROJECT_DOMAIN=frp.dengxiaonan.cn

# 项目时区，默认 Asia/Shanghai。
# 只有需要改变项目时间行为时才打开修改。
PROJECT_TIMEZONE=Asia/Shanghai

# 服务监听配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8443
SERVER_RELOAD=true

# HTTPS 证书配置。frp tcp 透传时，外部 HTTPS 会原样透到本地，
# 所以这里需要填写 frp.dengxiaonan.cn 对应证书和私钥路径。
# 示例：
# SERVER_SSL_CERTFILE=certs/fullchain.pem
# SERVER_SSL_KEYFILE=certs/privkey.pem
SERVER_SSL_CERTFILE=certs/frp.dengxiaonan.cn_bundle.pem
SERVER_SSL_KEYFILE=certs/frp.dengxiaonan.cn.key

# 模块 / 路由加载配置
# 加载某个目录下的所有子模块，例如 auto -> auto.cfg
ROUTER_MODULE_GROUPS=["auto"]

# 加载单个普通模块，不要求模块里有 router
ROUTER_MODULES=[]

# 加载单个 router 模块
ROUTER_FOLDERS=[]

#加载自身带 router、子目录为普通模块的模块组
ROUTER_GROUPS=["修仙"]

# 加载某个目录下所有带 router 的子模块
ROUTER_CHILD_FOLDERS=[]

# 通信适配器配置。可选值：qq、ws。
ADAPTERS=["qq","ws"]

# 自定义配置示例 主人名称
# 读取方式：config.MASTER_NAME
MASTER_NAME=["邓大楠","邓晓楠"]

# QQ 开放平台 Webhook 回调
# 回调地址路径默认 /qq/events，完整本地地址：http://127.0.0.1:8443/qq/events
# 开放平台正式回调需要 HTTPS；可用反代或内网穿透把外部 HTTPS 转到本机 8443。
QQ_EVENT_PATH=/qq/events
QQ_BOT_APP_ID=
QQ_BOT_SECRET=
